# Copy this to .env and fill in your actual values
# NEVER commit .env to git

# --- LLM provider selection ---
# Options: claude, openai, deepseek, gemini, ollama
LLM_PROVIDER=claude
# Optional: override the default model for the chosen provider
# LLM_MODEL=deepseek-chat

# --- LLM API keys (only the one you use is required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=...
# For Ollama (local, no key needed): set base URL if not default localhost
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Audio (Azure TTS) ---
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# --- Publishing (GitHub) ---
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USER=your_github_username
GITHUB_REPO=ai-dev-daily-podcast
PODCAST_EMAIL=your@email.com
